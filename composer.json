{
  "name": "siddik-web/wp-ai-kit",
  "description": "Production-grade starter kit for AI-assisted WordPress development.",
  "type": "project",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Md Siddiqur Rahman",
      "email": "siddikcoder@gmail.com"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "humanmade/psalm-plugin-wordpress": "^3.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpunit/phpunit": "^9.6",
    "vimeo/psalm": "^6.16",
    "wp-coding-standards/wpcs": "^3.1",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "autoload": {
    "classmap": [
      "top-announcement-banner/includes/"
    ]
  },
  "scripts": {
    "lint": "phpcs --standard=phpcs.xml.dist",
    "lint:fix": "phpcbf .",
    "psalm": "./vendor/bin/psalm",
    "test": "phpunit --configuration phpunit.xml.dist",
    "test:security": "grep -R --line-number --include='*.php' -E '\\beval\\s*\\(|\\bassert\\s*\\(' top-announcement-banner && exit 1 || exit 0",
    "test:performance": "php -r \"echo 'No dedicated performance suite configured.' . PHP_EOL;\""
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  }
}
