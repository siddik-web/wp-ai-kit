{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ES2021"
  },
  "include": [
    "src/**/*.js",
    "top-announcement-banner/assets/**/*.js",
    "top-announcement-banner/src/**/*.js",
    "tests/**/*.js",
    "*.js"
  ],
  "exclude": [
    "node_modules",
    "vendor",
    "dist",
    "top-announcement-banner/build"
  ]
}
