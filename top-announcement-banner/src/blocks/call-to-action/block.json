{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wp-ai-kit/call-to-action",
  "version": "1.0.0",
  "title": "Call to Action",
  "category": "design",
  "icon": "megaphone",
  "description": "A call-to-action section with a title and a linked button.",
  "keywords": ["cta", "button", "call to action", "promotion"],
  "textdomain": "top-announcement-banner",
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "padding": true,
      "blockGap": true
    },
    "typography": {
      "fontSize": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": ""
    },
    "buttonText": {
      "type": "string",
      "default": ""
    },
    "buttonUrl": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.scss",
  "style": "file:./style.scss"
}
