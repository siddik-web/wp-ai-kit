{
  "name": "wp-ai-kit",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade starter kit for AI-assisted WordPress development.",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/wp-ai-kit.git"
  },
  "author": "Your Name <you@example.com>",
  "license": "GPL-2.0-or-later",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "setup": "npm install",
    "setup:dev": "npm install && npm run lint && npm test",
    "build": "webpack --config webpack.config.js",
    "build:production": "webpack --config webpack.prod.js --mode production",
    "build:blocks": "wp-scripts build --webpack-src-dir=top-announcement-banner/src --output-path=top-announcement-banner/build",
    "start:blocks": "wp-scripts start --webpack-src-dir=top-announcement-banner/src --output-path=top-announcement-banner/build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:js": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:wordpress": "echo \"Run WordPress PHP tests with Composer or WP-CLI.\"",
    "test:e2e": "playwright test",
    "test:performance": "echo \"Run performance analysis with Lighthouse or custom tooling.\"",
    "audit:security": "npm audit --audit-level=high",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "devDependencies": {
    "@wordpress/scripts": "^24.0.0",
    "@wordpress/blocks": "^14.0.0",
    "@wordpress/block-editor": "^14.0.0",
    "@wordpress/components": "^28.0.0",
    "@wordpress/element": "^6.0.0",
    "@wordpress/i18n": "^5.0.0",
    "bundlesize": "^0.17.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.0.0",
    "eslint-plugin-jsx-a11y": "^6.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "jest": "^29.0.0",
    "lighthouse": "^11.0.0",
    "playwright": "^1.40.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.80.0",
    "webpack-bundle-analyzer": "^4.0.0",
    "webpack-cli": "^5.0.0",
    "core-js": "^3.37.0",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "babel-loader": "^9.0.0",
    "css-loader": "^6.8.0",
    "postcss": "^8.4.0",
    "postcss-loader": "^7.4.0",
    "autoprefixer": "^10.4.0",
    "sass": "^1.70.0",
    "sass-loader": "^13.3.0",
    "style-loader": "^3.5.0",
    "mini-css-extract-plugin": "^2.7.0"
  }
}
